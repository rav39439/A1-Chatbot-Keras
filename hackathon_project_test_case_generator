# -----------------------------
# Utility: Clean Markdown
# -----------------------------
def clean_llm_output(text: str) -> str:
    """
    Removes markdown code blocks safely.
    """
    text = text.replace("```python", "")
    text = text.replace("```", "")
    return text.strip()


def extract_python_code(text: str) -> str:
    """
    Extracts Python code from LLM output.
    Handles cases like:
    - ```python ... ```
    - ``` ... ```
    - mixed text before/after code blocks
    """

    if not text:
        return ""

    # Case 1: explicit ```python blocks
    pattern = r"```python(.*?)```"
    matches = re.findall(pattern, text, re.DOTALL | re.IGNORECASE)

    if matches:
        return "\n\n".join(match.strip() for match in matches)

    # Case 2: generic ``` blocks
    pattern = r"```(.*?)```"
    matches = re.findall(pattern, text, re.DOTALL)

    if matches:
        return "\n\n".join(match.strip() for match in matches)

    # Case 3: fallback (no markdown found → return raw text)
    return text.strip()
def generate_test_scenarios(
    endpoint: str,
    method: str,
    function_description: str,
    input_schema,
    output_schema,
    query_parameters=None,
    more_info: str = ""
):
    if query_parameters is None:
        query_parameters = []

    system_prompt = SystemMessage(
        content="""
        You are an expert QA automation engineer for REST APIs.

        Analyze only: API Description, Method, Endpoint (including query params), Input Schema, Output Schema, and More Info. Do not assume anything not provided.

        Generate test scenarios in 4 categories:

        schema_validation_tests: Validate API response strictly against the Output Schema using runtime-style assertions. Each assertion must explicitly describe a validation check such as field existence, data type validation, nested structure validation, and strict schema compliance including detection of missing or extra fields. All assertions must be full executable validation statements.
        contract_tests: Validate API contract correctness using runtime checks. This includes HTTP method validation, endpoint structure validation, query parameter validation, and response consistency across valid inputs. All assertions must be complete validation statements.
        negative_tests: Validate invalid scenarios such as missing parameters, invalid values, and malformed requests. Each test must include an expected HTTP status code and at least one runtime validation assertion for error response structure or message validation.
        boundary_tests: Validate edge cases such as minimum values, maximum values, empty inputs, and extreme values. Assertions must describe expected API behavior in a testable way.
        more_info_tests: Generate additional test scenarios derived only from "More Info" and User Query. These must reflect real-world usage, business rules (if provided), and user intent-driven edge cases. Do not duplicate other categories unless required by context.


        Rules:
        You may modify query parameters freely for test coverage.
        Modify input schema only for POST/PUT (add/remove/update fields if needed).
        Schema validation tests must strictly follow Output Schema structure.
        Do not assume hidden fields, business rules, or extra response keys.
        Arrays/objects must always retain their defined structure.

        Output ONLY valid JSON in this format:
        {
        "schema_validation_tests": [],
        "contract_tests": [],
        "negative_tests": [],
        "boundary_tests": [],
        "more_info_tests": []
        }

        No explanations, no markdown, no extra text.
"""
    )

    user_prompt = HumanMessage(
        content=f"""
    Endpoint: {endpoint}
    Method: {method}

    Description:
    {function_description}

    Input Schema:
    {json.dumps(input_schema, indent=2)}

    Output Schema:
    {json.dumps(output_schema, indent=2)}

    Query Parameters:
    {json.dumps(query_parameters, indent=2)}

    More Info:
    {more_info}
"""
    )

    response = llm.invoke([system_prompt, user_prompt])

    raw_output = response.content.strip()

    # Clean accidental markdown if present
    raw_output = raw_output.replace("```json", "").replace("```", "").strip()

    try:
        parsed_json = json.loads(raw_output)
    except json.JSONDecodeError:
        print("Invalid JSON returned by LLM:")
        print(raw_output)
        raise

    return parsed_json

