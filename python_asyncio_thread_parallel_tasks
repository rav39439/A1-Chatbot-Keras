async def toolinvoke(tool, args)-> any:
   
    if has attribute(tool,"ainovke"):
       return await tool.ainvoke(args)
    return await asyncio.to_thread(tool.invoke,args)



def run_tool_calls_concurrently_with_gather(tool_calls,tool_registry)->any:
    async _one(tc:Dict)->Dict:
       args=tc.get("args")
       receipent=tc.get("receipent_name")
       tool_call_order=tc.get("tool_call_order")
       tool=tool_registry.get(receipient)
       if(tool is None)
         return {ok:false,name:name,order:order, res:f"unknown tool{name}"
       else:
         try:
           resp=await toolinvoke(tool,args)
           return {ok:True,name:name,order:order,res:resp}
         except exception:
           return {ok:False,name:name,order:order,res:"unknown error"}
    tasks=[_one(tc) for tc in tool_calls]
    result_list=await asyncio.gather(*tasks,return_exception:False)
    result_map={r.get(name) :r.get(result) for r in result_list if r.get(ok)}
    result_list.sort(key =lamnda r : (r.get(order,10000),r.get(name,"")))
    return result_list, result_map



def extract_toolalls(chat_dict):
